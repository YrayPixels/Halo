DATABASE_URL="postgresql://halo:halo@localhost:5432/halo?schema=public"
REDIS_URL="redis://localhost:6379"
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

# Executor / Jito bundle submission
JITO_BLOCK_ENGINE_URL="mainnet.block-engine.jito.wtf"
EXECUTOR_PRIVATE_KEY=""
TRANSFER_DESTINATION=""
TRANSFER_LAMPORTS="1000"
JITO_MIN_TIP_LAMPORTS="0"
MAX_BUNDLE_ATTEMPTS="4"

# Set true to submit with an expired blockhash (fault injection demo)
FAULT_INJECT_EXPIRED_BLOCKHASH="false"

# Run executor as retry daemon (listens for agent retry requests)
EXECUTOR_DAEMON="false"

# Steady agent telemetry intervals (ms)
TIP_AGENT_INTERVAL_MS="30000"
LEADER_AGENT_INTERVAL_MS="15000"

# Optional LLM for final agent synthesis (falls back to heuristic reasoning)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Yellowstone gRPC (Triton, Helius, Tatum, etc.)
YELLOWSTONE_GRPC_URL="https://your-endpoint.example.com:10000"
YELLOWSTONE_GRPC_TOKEN="your-x-token"
