{
  "name": "halo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:all": "pnpm infra:up && pnpm db:migrate && concurrently -n watcher,tracker,intelligence,dashboard -c yellow,cyan,magenta,green \"pnpm dev:watcher\" \"pnpm dev:tracker\" \"pnpm dev:intelligence\" \"pnpm dev:dashboard\"",
    "dev:intelligence": "pnpm --filter @halo/intelligence dev",
    "dev:executor:daemon": "EXECUTOR_DAEMON=true pnpm --filter @halo/executor dev",
    "dev:watcher": "pnpm --filter @halo/watcher dev",
    "dev:executor": "pnpm --filter @halo/executor dev",
    "dev:tracker": "pnpm --filter @halo/tracker dev",
    "dev:dashboard": "pnpm --filter @halo/dashboard dev",
    "infra:up": "docker compose up -d postgres redis",
    "db:migrate": "pnpm --filter @halo/database db:migrate",
    "db:generate": "pnpm --filter @halo/database db:generate",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@types/node": "latest",
    "concurrently": "^10.0.3",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
