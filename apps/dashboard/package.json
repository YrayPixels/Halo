    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "ioredis": "^5.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.16"
